# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION (EXAMPLE)
# ==============================================================================
# Copy this file to .env and replace the values with your actual configuration.
# DO NOT commit the actual .env file to version control.

# --- SERVER SETTINGS ---
PORT=3000
# FRONTEND_URL=https://your-frontend-domain.com
FRONTEND_URL=http://<YOUR_SERVER_IP_ADDRESS>

# --- AUTHENTICATION ---
# Generate a secure random string for JWT_SECRET (e.g. using `openssl rand -base64 32`)
JWT_SECRET=your_super_secret_jwt_key_here

# --- DATABASE ---
# MongoDB Connection String
MONGO_URL=mongodb://username:password@host:port/database

# --- REDIS (UPSTASH) ---
# Used for rate limiting and caching
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# --- THIRD-PARTY APIs ---
# VDoCipher (Video Hosting)
VDOCIPHER_API_SECRET=your_vdocipher_api_secret

# Resend (Email Service)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="Your App Name <noreply@yourdomain.com>"

# --- AWS S3 (Storage) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET=your_s3_bucket_name
