        "./src/modules/auth/dto/register-send-otp.dto.ts",
        "./src/modules/auth/dto/register-verify-otp.dto.ts",
        "./src/modules/auth/schemas/user.schema.ts",
        "./src/modules/courses/courses.controller.ts",
        "./src/modules/courses/courses.module.ts",
        "./src/modules/courses/courses.service.ts",
        "./src/modules/courses/hls.service.ts",
        "./src/modules/courses/dto/get-courses.dto.ts",
        "./src/modules/courses/dto/update-class-progress.dto.ts",
