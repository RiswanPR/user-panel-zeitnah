{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node10",
        "target": "es2021",
        "lib": [
            "es2021"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "sourceMap": true,
        "removeComments": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "incremental": true,
        "strict": false,
